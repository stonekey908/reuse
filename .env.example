# Reuse — multi-provider runner config.
# Copy this file to .env and fill in only the providers you want to use.
# The Analysis tab will show which providers are configured and let you pick a model.

# Anthropic Claude (recommended default)
# Get a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Google Gemini
# Get a key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-key-here

# Ollama (local LLM, no API key needed). The default URL is http://localhost:11434.
# Override only if you run Ollama on a different host/port.
# OLLAMA_BASE_URL=http://localhost:11434
